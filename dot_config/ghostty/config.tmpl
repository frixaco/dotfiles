theme = dark:cyberdream,light:cyberdream-light

{{- if eq .chezmoi.os "darwin" }}
command = /opt/homebrew/bin/fish --login --interactive
{{- else if eq .chezmoi.os "linux" }}
command = /usr/bin/fish --login --interactive
{{- end }}

window-padding-x = 8
window-padding-y = 4,0

clipboard-read = allow
clipboard-write = allow

background-opacity = 1
background-blur = 40
split-divider-color = #bd5eff

macos-titlebar-style = "tabs"
gtk-titlebar = true
gtk-titlebar-style = tabs
macos-option-as-alt = left
window-vsync = false

font-size = 14
font-family = "IBM Plex Mono"

window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true

keybind = ctrl+1=goto_tab:1
keybind = ctrl+2=goto_tab:2
keybind = ctrl+3=goto_tab:3
keybind = ctrl+4=goto_tab:4
keybind = ctrl+5=goto_tab:5

keybind = cmd+t=new_tab

keybind = alt+h=goto_split:left
keybind = alt+j=goto_split:down
keybind = alt+k=goto_split:up
keybind = alt+l=goto_split:right

keybind = alt+ctrl+h=resize_split:left,10
keybind = alt+ctrl+j=resize_split:down,10
keybind = alt+ctrl+k=resize_split:up,10
keybind = alt+ctrl+l=resize_split:right,10

keybind = cmd+shift+p=toggle_command_palette
